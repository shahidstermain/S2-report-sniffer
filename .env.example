# S2 Report Sniffer — environment variables
# Copy this file to .env and fill in values as needed.
# The application runs fully offline without any of these set.

# ── Storage ──────────────────────────────────────────────────────────────────
# Directory where SQLite database and parsed reports are stored.
# Defaults to ~/.s2-report-sniffer when unset.
# S2RS_DATA_DIR=/path/to/data

# Storage backend (only "local" is implemented).
STORAGE_BACKEND=local

# ── Server ───────────────────────────────────────────────────────────────────
# Bind address for gunicorn / uvicorn.
# BIND=0.0.0.0:8000

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins.
# Required when the frontend is served from a different origin than the API.
# Must be explicit (no wildcards) because the API uses credentialed requests.
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.example.com

# ── Optional S3 export ───────────────────────────────────────────────────────
# Leave blank to disable S3 integration.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=

# ── Glean MCP integration ────────────────────────────────────────────────────
# Configure via the /api/glean/config endpoint or the UI; no env vars required.

# ── Hostinger VPS integration ────────────────────────────────────────────────
# HOSTINGER_API_TOKEN=

# ── UI directory override (desktop builds) ───────────────────────────────────
# S2RS_UI_DIR=/path/to/frontend/build

# ── Developer flags ──────────────────────────────────────────────────────────
# Set to 1 to log all registered routes on startup.
# S2RS_LOG_ROUTES=1

# Set to 1 to disable GZip response compression.
# S2RS_DISABLE_GZIP=0
